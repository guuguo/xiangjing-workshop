{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "像境工坊",
  "version": "0.1.1",
  "identifier": "com.guuguo.image-lab",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:4192",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": {
        "default-src": ["'self'", "ipc:", "http://ipc.localhost"],
        "connect-src": ["ipc:", "http://ipc.localhost"],
        "img-src": ["'self'", "asset:", "http://asset.localhost", "https://asset.localhost", "data:"],
        "style-src": ["'self'", "'unsafe-inline'"]
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPLOCALDATA/**"]
      }
    },
    "windows": [{
      "title": "像境工坊",
      "width": 1280,
      "height": 820,
      "minWidth": 1060,
      "minHeight": 680,
      "titleBarStyle": "Overlay",
      "hiddenTitle": true,
      "trafficLightPosition": { "x": 18, "y": 20 },
      "acceptFirstMouse": true
    }]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/512x512.png",
      "icons/128x128.png",
      "icons/32x32.png"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
